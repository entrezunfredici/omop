{
  "id": "odoo-plugin",
  "name": "Odoo Plugin",
  "description": "Safe Odoo connector for OpenClaw with bounded CRUD tools",
  "version": "0.1.0",
  "skills": [
    "./skills"
  ],
  "settingsUrl": "/plugin/odoo/settings",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "active_connection_profile_id": {
        "type": "string",
        "default": "default",
        "description": "Profil de connexion actif par défaut. Gérez vos profils sur /plugin/odoo/settings"
      },
      "active_access_profile_id": {
        "type": "string",
        "default": "readonly",
        "description": "Profil d'accès actif par défaut."
      },
      "default_limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 200,
        "default": 25,
        "description": "Nombre maximum d'enregistrements retournés par odoo_read."
      },
      "read_only": {
        "type": "boolean",
        "default": true,
        "description": "Si activé, les opérations create/update/delete sont bloquées globalement même si les règles le permettent."
      }
    }
  },
  "uiHints": {
    "labels": {
      "active_connection_profile_id": "Profil de connexion actif",
      "active_access_profile_id": "Profil d'accès actif",
      "default_limit": "Limite de lecture par défaut",
      "read_only": "Mode lecture seule global"
    },
    "active_connection_profile_id": {
      "label": "Profil de connexion actif",
      "placeholder": "default",
      "hint": "Gérez vos profils sur /plugin/odoo/settings"
    },
    "active_access_profile_id": {
      "label": "Profil d'accès actif",
      "placeholder": "readonly"
    },
    "default_limit": {
      "label": "Limite de lecture par défaut",
      "placeholder": "25"
    },
    "read_only": {
      "label": "Mode lecture seule global"
    }
  }
}
